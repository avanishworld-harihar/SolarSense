# Canonical site URL for metadata, OG images, and PWA (include https in production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Server-only optional admin allowlist fallback (comma-separated):
ADMIN_USER_IDS=
ADMIN_PHONES=
# Server-only: bill training uploads (Storage + verified_bills_training). Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=
# AI provider switch: anthropic
BILL_AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# Optional: claude-3-5-haiku-latest | claude-3-5-sonnet-latest
ANTHROPIC_MODEL=claude-3-5-haiku-latest
ANTHROPIC_HAIKU_MODEL=claude-3-5-haiku-latest
ANTHROPIC_SONNET_MODEL=claude-3-5-sonnet-latest
# Optional CSV fallback order if primary model is unavailable for your key.
# Example: claude-3-haiku-20240307,claude-3-sonnet-20240229
ANTHROPIC_MODEL_FALLBACKS=
ANTHROPIC_ENABLE_SONNET_FALLBACK=true
AI_MIN_PARSE_CONFIDENCE=45
AI_MIN_FILLED_MONTHS=3
ANTHROPIC_TIMEOUT_MS=20000

# ── Sol.52 CRM v2 — multi-source lead ingestion ──────────────────────────────
# Shared secret for server-to-server callers (your own backends, Zapier, etc.).
# Compute the header as: x-sol52-key = HMAC-SHA256(rawBody, SOL52_INBOUND_SECRET) hex.
SOL52_INBOUND_SECRET=

# WhatsApp Cloud API webhook (https://<host>/api/webhooks/whatsapp)
# WA_VERIFY_TOKEN is whatever string you typed into the Meta dashboard during
# the GET handshake. WA_APP_SECRET is the App Secret found at
# Meta App → Settings → Basic → App Secret. Used to verify
# `X-Hub-Signature-256` on every POST.
WA_VERIFY_TOKEN=
WA_APP_SECRET=

# Meta Lead Ads webhook (https://<host>/api/webhooks/meta-leads)
# Same App Secret as above (re-declared for clarity); the long-lived Page
# Access Token is required so the webhook can call /<lead-id>?access_token=…
# to expand each leadgen ID into form fields.
META_APP_SECRET=
META_LEAD_PAGE_TOKEN=
META_VERIFY_TOKEN=
